@model BoardGameRent.Web.Models.Juego

@{
    bool isEditMode = Model != null && Model.Id > 0;

    ViewData["Title"] = isEditMode ? "Editar Juego" : "Agregar Juego";
    
    // IMPORTANTE: Los nombres aquí deben coincidir EXACTAMENTE con tus métodos POST del controlador
    string accion = isEditMode ? "EditarJuego" : "CrearJuego";
}
<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="card shadow-lg border-0" style="border-radius: 12px; overflow: hidden;">
                <div class="card-header border-0 py-4" style="background-color: var(--color-900); color: var(--color-50);">
                    <h3 class="mb-0 fw-bold d-flex align-items-center gap-2">
                        @(isEditMode ? $"✏️ Editar: {Model.Nombre}" : "🎮 Agregar Nuevo Juego")
                    </h3>
                </div>
                <div class="card-body p-5" style="background-color: var(--color-50);">

                    <!-- El formulario apunta dinámicamente al endpoint correcto -->
                    <form asp-action="@accion" method="post">

                        <!-- Si es edición, inyectamos los campos ocultos -->
                        @if (isEditMode)
                        {
                            <input type="hidden" asp-for="Id" />
                            <input type="hidden" asp-for="EstaDisponible" />
                        }
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4 fw-bold"></div>
                        
                        <div class="mb-4">
                            <label asp-for="Nombre" class="form-label fw-bold" style="color: var(--color-900);">Nombre del Juego</label>
                            <input asp-for="Nombre" class="form-control form-control-lg shadow-sm" style="border: 2px solid var(--color-200); border-radius: 8px; background-color: white;" placeholder="Ej: Catan" />
                            <span asp-validation-for="Nombre" class="text-danger fw-semibold mt-1 d-block"></span>
                        </div>
                        
                        <div class="mb-4">
                            <label asp-for="Descripcion" class="form-label fw-bold" style="color: var(--color-900);">Descripción</label>
                            <textarea asp-for="Descripcion" class="form-control shadow-sm" rows="4" style="border: 2px solid var(--color-200); border-radius: 8px; background-color: white;" placeholder="Cuéntanos un poco sobre de qué trata el juego..."></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger fw-semibold mt-1 d-block"></span>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="PrecioPorDia" class="form-label fw-bold" style="color: var(--color-900);">Precio por Día</label>
                                <div class="input-group shadow-sm" style="border-radius: 8px;">
                                    <span class="input-group-text border-0" style="background-color: var(--color-300); color: var(--color-950); font-weight: bold;">$</span>
                                    <input asp-for="PrecioPorDia" type="number" step="0.01" class="form-control form-control-lg border-0" style="border-top: 2px solid var(--color-200) !important; border-bottom: 2px solid var(--color-200) !important; border-right: 2px solid var(--color-200) !important;" />
                                </div>
                                <span asp-validation-for="PrecioPorDia" class="text-danger fw-semibold mt-1 d-block"></span>
                            </div>
                            <div class="col-md-6 mb-4">
                                <label asp-for="ImageUrl" class="form-label fw-bold" style="color: var(--color-900);">URL de la Imagen</label>
                                <input asp-for="ImageUrl" class="form-control form-control-lg shadow-sm" style="border: 2px solid var(--color-200); border-radius: 8px; background-color: white;" placeholder="https://..." />
                                <span asp-validation-for="ImageUrl" class="text-danger fw-semibold mt-1 d-block"></span>
                            </div>
                        </div>
                        
                        <div class="d-flex justify-content-end mt-5 pt-4 border-top" style="border-color: var(--color-200) !important;">
                            <a asp-action="ListaJuegos" class="btn btn-lg me-3 fw-bold" style="color: var(--color-800); border: 2px solid var(--color-300); background-color: white; border-radius: 8px;">
                                Cancelar
                            </a>
                            <button type="submit" class="btn btn-lg px-5 fw-bold shadow" style="background-color: var(--color-600); color: white; border: none; border-radius: 8px; transition: transform 0.2s;">
                                @(isEditMode ? "💾 Guardar Cambios" : "✨ Crear Juego")
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
