<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BoardGameRent.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BoardGameRent.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark mb-4 py-3" style="background-color: var(--color-700); box-shadow: 0 4px 15px rgba(23, 130, 54, 0.4);">
            <div class="container">
                <a class="navbar-brand fw-bold fs-4 d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index" style="color: var(--color-50);">
                    <span style="font-size: 1.5rem;">🎲</span> BoardGameRent
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-md-4">
                        <li class="nav-item">
                            <a class="nav-link fw-bold px-3" asp-area="" asp-controller="Juegos" asp-action="ListaJuegos" style="color: var(--color-100);">Catálogo de Juegos</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav align-items-center gap-3 mt-3 mt-md-0">
                        <li class="nav-item">
                            <a class="nav-link fw-bold" asp-area="" asp-controller="Usuarios" asp-action="Login" style="color: var(--color-100);">Iniciar Sesión</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn fw-bold px-4 rounded-pill" href="#" style="background-color: var(--color-400); color: var(--color-950); border: none; box-shadow: 0 4px 12px rgba(5, 223, 114, 0.3); transition: all 0.2s;">
                                Registro Rápido
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light mt-5">
        <div class="container py-3 text-center">
            &copy; 2026 - BoardGameRent - Alquiler de Juegos de Mesa
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
